# Copia este archivo a ".env" y completa los valores antes de levantar los contenedores.

# Dominio con el que vas a acceder a la app (ej: descuentos.tudominio.cl)
# Debe apuntar (registro A) a la IP de esta VPS antes de levantar caddy.
DOMINIO=descuentos.tudominio.cl

# Base de datos
DB_USER=gasolinera
DB_PASSWORD=cambia-esta-clave-larga-y-unica
DB_NAME=gasolinera

# Seguridad de sesiones (usa una cadena larga y aleatoria, distinta a cualquier otra clave)
JWT_SECRET=cambia-este-secreto-largo-y-aleatorio

# Usuario administrador que se crea automáticamente la primera vez que arranca la app
ADMIN_USER=admin
ADMIN_PASSWORD=cambia-esta-clave-de-admin
